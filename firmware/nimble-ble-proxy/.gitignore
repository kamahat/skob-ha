build/
sdkconfig
sdkconfig.old
# ESPHome / lab secrets (WiFi creds etc.) — never commit
secrets.yaml
**/secrets.yaml
# Generated per-target sdkconfigs (idf.py set-target / -D SDKCONFIG=...).
# Keep the committed sdkconfig.defaults / sdkconfig.defaults.<target> files.
sdkconfig.*
!sdkconfig.defaults
!sdkconfig.defaults.*
# Alternate per-target build dirs (idf.py -B build_<target>).
build_*/
managed_components/
dependencies.lock

# clangd / IDE / language caches.
.cache/
.idea/
__pycache__/

# Real wifi credentials never committed — copy from wifi_creds.h.example.
include/wifi_creds.h

# Generated nanopb output.
components/api_proto/api_subset.pb.c
components/api_proto/api_subset.pb.h

# Vendored nanopb runtime (cloned per-host, see generate.sh).
components/api_proto/nanopb/

# MicroPython prototype lives in its own subtree; not part of the firmware build.
micropython/

build-bletest/log/

build-bletest/gdbinit/

build-bletest/

.playwright-mcp/
